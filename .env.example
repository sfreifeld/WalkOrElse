# Required for Oura API calls
OURA_ACCESS_TOKEN=

# Optional: timezone used to select "today" for Oura daily activity lookup
# Example: America/Los_Angeles
OURA_USER_TIMEZONE=UTC

# Optional: persisted state file path (defaults to ./data/oura-state.json)
# OURA_STATE_FILE_PATH=./data/oura-state.json
