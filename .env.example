# Hosted Postgres connection string (required)
# Use POSTGRES_URL for Vercel Postgres, or DATABASE_URL for Neon/other hosted providers.
POSTGRES_URL=
# DATABASE_URL=

# OAuth app credentials (required for GET /api/oura/callback)
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=

# Optional fallback token for Oura API.
# OAuth callback stores the latest token in Postgres and is preferred over this value.
OURA_ACCESS_TOKEN=

# OAuth redirect URI configuration.
# Recommended: set the exact callback URI registered in Oura.
OURA_REDIRECT_URI=

# Optional fallback for redirect URI derivation and UI links.
# If OURA_REDIRECT_URI is unset, callback uses ${NEXT_PUBLIC_APP_URL}/api/oura/callback.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: timezone used to select "today" for Oura daily activity lookup.
# Example: America/Los_Angeles
OURA_USER_TIMEZONE=UTC

# Required for image upload route (POST /api/shame-image/upload)
# Generate this in Vercel Blob storage settings.
BLOB_READ_WRITE_TOKEN=
