# OAuth app credentials (required when using GET /api/oura/callback to exchange ?code=…)
# Names must match exactly (not OURA_SECRET — use OURA_CLIENT_SECRET).
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=

# Bearer token for Oura API (set manually, or leave unset until OAuth callback stores it)
OURA_ACCESS_TOKEN=

# Optional: timezone used to select "today" for Oura daily activity lookup
# Example: America/Los_Angeles
OURA_USER_TIMEZONE=UTC

# Required for image upload route (POST /api/shame-image/upload)
# Generate this in Vercel Blob storage settings.
BLOB_READ_WRITE_TOKEN=

# Optional: SQLite file path for app persistence (defaults to ./data/walkorelse.db)
# DATABASE_FILE_PATH=./data/walkorelse.db
